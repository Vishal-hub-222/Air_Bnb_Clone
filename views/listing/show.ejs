<% layout("/layouts/boilerplate") %>
   
    <div class="row mt-3 ">
        <div class="col-8 offset-2">
             <h3> <%= listing.title%></h3>
             </div>
<div class="card col-8 offset-2  listing-card">
         <img src="<%=listing.image.url%>" class="card-img-top fixed-img show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
     <p> <strong> owned by : </strong><i><%= listing.owner.username %></i> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<strong>Created on:</strong><i> <%= listing.createdAt.toDateString() %></i></p>
     <%= listing.description%><br>
    &#8377;<%=listing.price ? listing.price.toLocaleString("en-IN") :"1200"%>/nigth<br>
    <%= listing.location%><br>
    <%= listing.country%><br>
    <%= listing.category %>
    </p>
  </div>
  </div>
 <% if(CurrrentUser && CurrrentUser._id.equals(listing.owner._id)) { %>
   
  <div class="btn">
   
        <form method="get" action="/listings/<%=listing._id%>/edit">
        <button class="btn btn-dark offset-2  v">edit</button>
    </form>
     
     
    <form method="post" action="/listings/<%=listing.id%>/delete?_method=DELETE">
        <button class="btn btn-dark offset-4 add-btn  v ">DELETE</button>

    </form>
    
 </div>
 <% } %>
 <hr>
 <% if(CurrrentUser) { %>
 <div class="col-8 offset-2 mb-3">
    <h3>Rating section</h3>
    <form action="/listings/<%=listing._id%>/review" method="post" class="needs-validation" novalidate >
        <div mb-3 mt-3>
            <fieldset class="starability-slot">
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
        </div>
        <div mb-3 mt-3>
            <label for="commet" class="form-label">Cmments</label>
            <textarea
            name="review[comment]"
            id="comment"
            cols="30"
            rows="5"
            class="form-control"
            placeholder="write something"
            required 
            ></textarea>
            <div class="invalid-feedback">pls write your review 😢...</div>
        </div>

      <button class="btn btn-outline-dark mt-3">Submit</button>
    </form>
 <% } %>
 <hr>
 <div class="row col-8 offset-2">
  <p class="fw-bold">Rating & Reviews</p>

  <% for(let review of listing.reviews) { %>
    
    <div class="col-12 col-md-6 mb-3">
      <div class="card shadow-sm h-100 review-card">
        
        <div class="card-body p-2">
          
          <!-- Username -->
          <h6 class="card-title mb-1">
            👤 @<%= review.author.username %>
          </h6>

          <!-- Stars -->
          <p class="starability-result mb-2" data-rating="<%= review.rating %>"></p>

          <!-- Comment -->
          <p class="card-text small text-muted">
            <%= review.comment %>
          </p>

        </div>

        <!-- Delete Button -->
        <div class="card-footer bg-white border-0 text-end">
          <form action="/listings/<%=listing._id%>/delete/<%= review._id %>?_method=DELETE" method="post">
            <button class="btn btn-sm btn-outline-danger">Delete</button>
          </form>
        </div>

      </div>
    </div>

  <% } %>
</div>
 </div>
 </div>
    

